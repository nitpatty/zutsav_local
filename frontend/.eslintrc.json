{
  "extends": ["react-app"],
  "plugins": ["react-hooks"],
  "rules": {
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "no-restricted-globals": [
      "error",
      "addEventListener", "blur", "close", "closed", "confirm",
      "defaultStatus", "event", "external", "find", "focus",
      "frameElement", "frames", "history", "innerHeight", "innerWidth",
      "length", "menubar", "moveBy", "moveTo", "name", "onblur",
      "onerror", "onfocus", "onload", "onresize", "onunload", "open",
      "opener", "opera", "outerHeight", "outerWidth", "pageXOffset",
      "pageYOffset", "parent", "print", "removeEventListener", "resizeBy",
      "resizeTo", "screen", "screenLeft", "screenTop", "screenX", "screenY",
      "scroll", "scrollbars", "scrollBy", "scrollTo", "scrollX", "scrollY",
      "self", "status", "statusbar", "stop", "toolbar", "top"
    ]
  }
}
