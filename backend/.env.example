PORT=5000
MONGO_URI=mongodb://localhost:27017/zutsav
JWT_SECRET=zutsav_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Razorpay (legacy — kept for old bookings)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# PhonePe Standard Checkout
# PHONEPE_ENV=uat   (use 'prod' for production)
PHONEPE_ENV=uat
PHONEPE_MERCHANT_ID=PGTESTPAYUAT86
PHONEPE_SALT_KEY=96434309-7796-489d-8924-ab56988a6076
PHONEPE_SALT_INDEX=1

# WhatsApp Cloud API (Meta Graph API)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_API_VERSION=v18.0

# Email Notifications (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
# Set to 'true' to send email AND WhatsApp (default: email only when WhatsApp not configured)
NOTIFY_ALWAYS_EMAIL=false

# Groq AI (llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key_here

# Admin Seed (auto-created on first server start)
ADMIN_NAME=Zutsav Admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=admin@zutsav.com
ADMIN_PASSWORD=Admin@123

# Google Apps Script — Festival / Tithi / Panchang Sync
# Deploy backend/google-apps-script/FestivalSync.gs as a Web App
# (Execute as: Me, Access: Anyone) then paste the generated URL here.
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwRQBm3RQYfmuhCZEMAdQqMFDub1i6bFaqv5kdnrD9SYW2cVAmmTJcnSkSD8Sj5GP9g/exec

# Tekipost Courier Integration
